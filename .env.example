# Docker Compose production example
# Copy this file to .env before running docker compose.

PAYLOAD_SECRET=change-this-to-a-strong-random-value-in-production
PAYLOAD_PUBLIC_SERVER_URL=https://your-domain.example

# Postgres container credentials used by docker-compose.yml.
POSTGRES_USER=payload
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=payload
