/** app.wxss **/

/* 全局基础重置与背景 */
page {
  background-color: #f8fafc;
  color: #1e293b;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

view, scroll-view, text, button, input, textarea, form, navigator {
  box-sizing: border-box;
}

/* 主题颜色变量与常用工具类 */
.color-primary { color: #3b82f6; }
.color-success { color: #10b981; }
.color-warning { color: #f59e0b; }
.color-danger { color: #ef4444; }
.color-secondary { color: #64748b; }

.bg-white { background-color: #ffffff; }
.bg-slate { background-color: #f1f5f9; }

/* 边距与间距 */
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }
.m-b-20 { margin-bottom: 20rpx; }
.m-b-30 { margin-bottom: 30rpx; }

/* Flex 布局工具 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.align-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }

/* 阴影与圆角卡片 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.03);
}

/* 按钮基础样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  border: none;
}

.btn-primary {
  background-color: #3b82f6;
  color: #ffffff;
}

.btn-primary-active {
  background-color: #2563eb;
}

.btn-secondary {
  background-color: #f1f5f9;
  color: #1e293b;
}

.btn-secondary-active {
  background-color: #e2e8f0;
}

.btn-outline {
  border: 2rpx solid #3b82f6;
  color: #3b82f6;
  background-color: transparent;
}

.btn-outline-active {
  background-color: rgba(59, 130, 246, 0.08);
}

/* 状态标签样式 */
.badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.badge-draft { background-color: #e2e8f0; color: #64748b; }
.badge-online { background-color: #dbeafe; color: #1e40af; }
.badge-coming { background-color: #fef3c7; color: #92400e; }
.badge-full { background-color: #fee2e2; color: #991b1b; }
.badge-offline { background-color: #f1f5f9; color: #475569; }

/* 文本单行省略和多行省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 详情项展示样式 */
.detail-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}
.detail-label {
  color: #64748b;
  width: 140rpx;
  flex-shrink: 0;
}
.detail-value {
  color: #1e293b;
  flex: 1;
}
