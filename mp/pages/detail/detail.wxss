.container {
  padding-bottom: 160rpx;
}

.loading-layout {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8fafc;
}

.loading-state,
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 80rpx 30rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.error-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 28rpx;
}

.btn-sm {
  font-size: 26rpx;
  padding: 16rpx 48rpx;
}

.swiper-wrap {
  position: relative;
  width: 100%;
  height: 480rpx;
  background-color: #e2e8f0;
}

.detail-swiper {
  width: 100%;
  height: 480rpx;
  background-color: #e2e8f0;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.swiper-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
  z-index: 2;
}

.detail-content {
  padding: 24rpx 30rpx;
}

.title-card {
  padding: 30rpx;
}

.m-l-10 {
  margin-left: 10rpx;
}

.update-lbl {
  font-size: 22rpx;
  color: #94a3b8;
}

.project-title-large {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.4;
}

.card-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  border-left: 6rpx solid #3b82f6;
  padding-left: 16rpx;
  margin-bottom: 24rpx;
  height: 28rpx;
  line-height: 28rpx;
}

.green-title {
  border-left-color: #10b981;
}

.red-title {
  border-left-color: #ef4444;
}

.params-table {
  display: flex;
  flex-direction: column;
}

.param-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 26rpx;
}

.param-row:last-child {
  border-bottom: none;
}

.param-label {
  color: #64748b;
  width: 180rpx;
  flex-shrink: 0;
}

.param-val {
  color: #1e293b;
  text-align: right;
  flex: 1;
}

.param-row-active {
  opacity: 0.6;
}

.address-val {
  font-size: 26rpx;
}

.address-text {
  text-align: right;
  word-break: break-all;
}

.copy-hint-text {
  font-size: 20rpx;
  color: #3b82f6;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.copy-icon {
  font-size: 24rpx;
  margin-left: 4rpx;
  flex-shrink: 0;
}


.font-bold {
  font-weight: 600;
}

.highlight-val {
  color: #ef4444;
  font-weight: 700;
}

.biz-tag-container {
  padding-left: 10rpx;
}

.biz-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.tag-green {
  background-color: #ecfdf5;
  color: #047857;
  border: 1rpx solid #d1fae5;
}

.tag-red {
  background-color: #fef2f2;
  color: #b91c1c;
  border: 1rpx solid #fee2e2;
}

.highlight-item {
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.bullet-dot {
  color: #3b82f6;
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1;
}

.highlight-text {
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

.desc-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
  text-align: justify;
}

.safe-bottom-space {
  height: 90rpx;
}

.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 120rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e2e8f0;
  box-shadow: 0 -4rpx 16rpx rgba(15, 23, 42, 0.04);
  padding: 10rpx 30rpx;
  z-index: 100;
}

.favorite-action {
  width: 100rpx;
  margin-right: 20rpx;
  height: 100%;
}

.fav-icon {
  font-size: 42rpx;
  color: #94a3b8;
  line-height: 1;
  transition: transform 0.1s ease;
}

.fav-active {
  color: #f59e0b;
}

.fav-lbl {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 2rpx;
}

.share-action {
  width: 100rpx;
  margin-right: 20rpx;
  height: 100%;
  background: transparent;
  padding: 0;
  margin: 0;
  border-radius: 0;
  line-height: normal;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.share-action::after {
  border: none;
}

.share-icon {
  font-size: 42rpx;
  color: #94a3b8;
  line-height: 1;
}

.share-lbl {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 2rpx;
}

.favorite-action:active,
.share-action:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.action-btn {
  height: 84rpx;
  font-size: 28rpx;
  line-height: 1.5;
}
