/* pages/success/success.wxss */

.success-container {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 90vh;
}

.success-card {
  width: 100%;
  padding: 60rpx 40rpx;
  text-align: center;
}

.success-icon {
  margin-bottom: 40rpx;
}

.success-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 24rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
  text-align: center;
  padding: 0 10rpx;
}

/* 按钮组 */
.btn-group {
  width: 100%;
  margin-top: 40rpx;
}

.action-btn {
  width: 100% !important;
  height: 90rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.action-btn:last-child {
  margin-bottom: 0;
}
