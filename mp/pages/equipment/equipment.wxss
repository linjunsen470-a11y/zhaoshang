@import "../apply/apply.wxss";

.type-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 8rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 12rpx;
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 600;
  background: #eff6ff;
}

.type-tab.active {
  background: #2563eb;
  color: #ffffff;
}
