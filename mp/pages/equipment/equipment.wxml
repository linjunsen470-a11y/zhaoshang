<view class="container form-page">
  <view class="form-header card">
    <view class="form-title">{{isEditMode ? '修改供需信息' : '设备供需登记'}}</view>
    <view class="form-desc">发布餐饮设备出售、求购或回收需求，平台协助撮合。</view>
  </view>

  <view class="type-tabs card">
    <view class="type-tab {{leadType === 'equipment_sell' ? 'active' : ''}}" bindtap="onTypeTap" data-type="equipment_sell">出售设备</view>
    <view class="type-tab {{leadType === 'equipment_buy' ? 'active' : ''}}" bindtap="onTypeTap" data-type="equipment_buy">求购设备</view>
    <view class="type-tab {{leadType === 'equipment_recycle' ? 'active' : ''}}" bindtap="onTypeTap" data-type="equipment_recycle">回收咨询</view>
  </view>

  <view class="form-card card">
    <view class="form-item">
      <view class="item-label">称呼</view>
      <input class="item-input" type="text" maxlength="20" placeholder="例如：陈老板" bindinput="onInputName" value="{{name}}" />
    </view>
    <view class="form-item">
      <view class="item-label">手机号</view>
      <input class="item-input" type="number" maxlength="11" placeholder="用于顾问联系" bindinput="onInputPhone" value="{{phone}}" />
    </view>
    <view class="form-item">
      <view class="item-label">设备名称</view>
      <input class="item-input" type="text" maxlength="100" placeholder="例如：冷藏柜、制冰机、炒炉、操作台" bindinput="onInputEquipmentName" value="{{equipmentName}}" />
    </view>
    <view class="form-item">
      <view class="item-label">数量/规格</view>
      <input class="item-input" type="text" maxlength="100" placeholder="例如：双门、八成新、220V" bindinput="onInputSpec" value="{{specText}}" />
    </view>
    <view class="form-item">
      <view class="item-label">设备状态</view>
      <input class="item-input" type="text" maxlength="100" placeholder="例如：正常使用、轻微划痕、需自提" bindinput="onInputCondition" value="{{equipmentCondition}}" />
    </view>
    <view class="form-item">
      <view class="item-label">{{leadType === 'equipment_buy' ? '采购预算' : '期望价格'}}</view>
      <input class="item-input" type="text" maxlength="100" placeholder="例如：3000 元以内，可议" bindinput="onInputBudget" value="{{budgetRange}}" />
    </view>
    <view class="form-item">
      <view class="item-label">所在区域</view>
      <input class="item-input" type="text" maxlength="50" placeholder="例如：广州大学城、天河" bindinput="onInputRegion" value="{{regionPreference}}" />
    </view>
    <view class="form-item">
      <view class="item-label">补充说明</view>
      <textarea class="item-textarea" maxlength="500" placeholder="例如：可自提、需发票、希望本周成交" bindinput="onInputRemark" value="{{remark}}" />
    </view>
    <view class="form-item border-none">
      <view class="item-label">设备图片 <text class="label-hint">最多 6 张，上传前自动压缩</text></view>
      <view class="attachment-grid">
        <view class="attachment-card" wx:for="{{attachments}}" wx:key="id">
          <image class="attachment-img" src="{{item.displayUrl}}" mode="aspectFill" bindtap="onPreviewAttachment" data-url="{{item.displayUrl}}" />
          <text class="attachment-remove" bindtap="onRemoveImage" data-index="{{index}}">×</text>
        </view>
        <view class="upload-tile" bindtap="onChooseImages" wx:if="{{attachments.length < 6}}">
          <text class="upload-plus">+</text>
          <text class="upload-hint">{{uploadingImages ? '上传中' : '添加图片'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="privacy-consent" wx:if="{{!isEditMode}}" bindtap="onTogglePrivacy">
    <checkbox checked="{{privacyAccepted}}" color="#3b82f6" />
    <text class="privacy-text">我已阅读并同意</text>
    <text class="privacy-link" catchtap="onGoPrivacy">《隐私政策》</text>
  </view>

  <view class="form-actions">
    <button class="btn btn-primary" loading="{{submitting}}" disabled="{{submitting || uploadingImages}}" bindtap="onSubmitForm">{{isEditMode ? '保存修改' : '提交设备需求'}}</button>
  </view>
</view>
