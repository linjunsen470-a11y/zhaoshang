<view class="container">
  <view class="user-header-bg">
    <view class="user-card flex align-center">
      <image src="{{userInfo.avatarUrl}}" mode="aspectFill" class="user-avatar" />
      <view class="user-info flex-1">
        <view class="flex align-center">
          <text class="user-name">{{userInfo.nickname || '未设置称呼'}}</text>
          <text class="user-role-badge">意向商户</text>
        </view>
        <view class="user-phone">联系手机：{{userInfo.phone || '提交咨询时填写'}}</view>
      </view>
      <view class="edit-btn" bindtap="onEditProfile">编辑</view>
    </view>
  </view>

  <view class="menu-list-container">
    <view class="card menu-card">
      <view class="menu-item flex align-center justify-between" bindtap="onGoToLeads">
        <view class="flex align-center">
          <text class="menu-icon">▣</text>
          <text class="menu-text">我的咨询记录</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item flex align-center justify-between" bindtap="onGoToFavorites">
        <view class="flex align-center">
          <text class="menu-icon">☆</text>
          <text class="menu-text">我的收藏项目</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="card menu-card">
      <view class="menu-item flex align-center justify-between" bindtap="onGoToPrivacy">
        <view class="flex align-center">
          <text class="menu-icon">◎</text>
          <text class="menu-text">隐私政策</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item flex align-center justify-between" bindtap="onCallService">
        <view class="flex align-center">
          <text class="menu-icon">☎</text>
          <text class="menu-text">联系招商客服</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item flex align-center justify-between border-none" bindtap="onShowAbout">
        <view class="flex align-center">
          <text class="menu-icon">i</text>
          <text class="menu-text">关于招商宝平台</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="edit-modal-mask flex align-center justify-center" wx:if="{{showEditModal}}">
    <view class="edit-modal-box card">
      <view class="modal-title">编辑联系信息</view>
      <view class="modal-desc">修改后，提交咨询时将自动填充新信息。咨询记录按当前微信账号关联，与手机号修改无关。</view>

      <view class="modal-form">
        <view class="modal-form-item">
          <text class="modal-label">你的称呼</text>
          <input class="modal-input" type="text" placeholder="例如：张总"
                 bindinput="onNicknameInput" value="{{editNickname}}" />
        </view>

        <view class="modal-form-item border-none">
          <text class="modal-label">手机号码</text>
          <input class="modal-input" type="number" maxlength="11" placeholder="常用电话"
                 bindinput="onPhoneInput" value="{{editPhone}}" />
        </view>
      </view>

      <view class="modal-actions flex">
        <button class="btn btn-secondary flex-1 modal-btn" bindtap="onCancelEdit">取消</button>
        <button class="btn btn-primary flex-1 modal-btn" style="margin-left: 20rpx;" bindtap="onSaveEdit">保存</button>
      </view>
    </view>
  </view>
</view>
