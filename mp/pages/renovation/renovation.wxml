<view class="container form-page">
  <view class="form-header card">
    <view class="form-title">{{isEditMode ? '修改装修需求' : '商铺装修咨询'}}</view>
    <view class="form-desc">提交您的店铺面积、预算及风格要求，我们的装修顾问会为您推荐专业高效的校园施工团队。</view>
  </view>

  <view class="form-card card">
    <view class="form-item">
      <view class="item-label">称呼</view>
      <input class="item-input" type="text" maxlength="20" placeholder="例如：李老板" bindinput="onInputName" value="{{name}}" />
    </view>
    <view class="form-item">
      <view class="item-label">手机号</view>
      <input class="item-input" type="number" maxlength="11" placeholder="用于顾问联系" bindinput="onInputPhone" value="{{phone}}" />
    </view>
    <view class="form-item">
      <view class="item-label">店铺面积</view>
      <input class="item-input" type="text" maxlength="50" placeholder="例如：35m²" bindinput="onInputShopArea" value="{{shopArea}}" />
    </view>
    <view class="form-item">
      <view class="item-label">装修类型</view>
      <picker bindchange="onRenovationTypeChange" range="{{renovationTypes}}" value="{{renovationTypeIndex}}">
        <view class="picker-inner {{renovationTypeIndex === -1 ? 'placeholder' : ''}}">
          {{renovationTypeIndex === -1 ? '请选择装修类型' : renovationTypes[renovationTypeIndex]}}
        </view>
      </picker>
    </view>
    <view class="form-item">
      <view class="item-label">设计风格偏好</view>
      <input class="item-input" type="text" maxlength="50" placeholder="例如：现代简约、日式木质、茶饮INS风" bindinput="onInputDesignStyle" value="{{designStyle}}" />
    </view>
    <view class="form-item">
      <view class="item-label">装修预算</view>
      <input class="item-input" type="text" maxlength="50" placeholder="例如：3-5 万元" bindinput="onInputBudgetText" value="{{budgetText}}" />
    </view>
    <view class="form-item">
      <view class="item-label">期望开工时间</view>
      <input class="item-input" type="text" maxlength="50" placeholder="例如：两周内、暑假期间" bindinput="onInputExpectedStartDate" value="{{expectedStartDate}}" />
    </view>
    <view class="form-item">
      <view class="item-label">需求描述</view>
      <textarea class="item-textarea" maxlength="500" placeholder="例如：需要拆除旧墙、新做水电、加装排烟设施等" bindinput="onInputRemark" value="{{remark}}" />
    </view>
    <view class="form-item border-none">
      <view class="item-label">店铺现状照片 <text class="label-hint">最多 6 张，上传前自动压缩</text></view>
      <view class="attachment-grid">
        <view class="attachment-card" wx:for="{{attachments}}" wx:key="id">
          <image class="attachment-img" src="{{item.url || item.localPath}}" mode="aspectFill" bindtap="onPreviewAttachment" data-url="{{item.url || item.localPath}}" />
          <text class="attachment-remove" bindtap="onRemoveImage" data-index="{{index}}">×</text>
        </view>
        <view class="upload-tile" bindtap="onChooseImages" wx:if="{{attachments.length < 6}}">
          <text class="upload-plus">+</text>
          <text class="upload-hint">{{uploadingImages ? '上传中' : '添加图片'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="privacy-consent" wx:if="{{!isEditMode}}" bindtap="onTogglePrivacy">
    <checkbox checked="{{privacyAccepted}}" color="#3b82f6" />
    <text class="privacy-text">我已阅读并同意</text>
    <text class="privacy-link" catchtap="onGoPrivacy">《隐私政策》</text>
  </view>

  <view class="form-actions">
    <button class="btn btn-primary" loading="{{submitting}}" disabled="{{submitting || uploadingImages}}" bindtap="onSubmitForm">{{isEditMode ? '保存修改' : '提交咨询'}}</button>
  </view>
</view>
