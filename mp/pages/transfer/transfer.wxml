<view class="container form-page">
  <view class="form-header card">
    <view class="form-title">{{isEditMode ? '修改转让需求' : '委托店铺转让'}}</view>
    <view class="form-desc">提交店铺位置、当前业态和转让预期，平台顾问会协助核验并匹配接手方。</view>
  </view>

  <view class="form-card card">
    <view class="form-item">
      <view class="item-label">称呼</view>
      <input class="item-input" type="text" placeholder="例如：李老板" bindinput="onInputName" value="{{name}}" />
    </view>
    <view class="form-item">
      <view class="item-label">手机号</view>
      <input class="item-input" type="number" maxlength="11" placeholder="用于顾问联系" bindinput="onInputPhone" value="{{phone}}" />
    </view>
    <view class="form-item">
      <view class="item-label">店铺位置</view>
      <input class="item-input" type="text" placeholder="例如：从化某高校商业街中段" bindinput="onInputLocation" value="{{locationText}}" />
    </view>
    <view class="form-item">
      <view class="item-label">当前业态</view>
      <input class="item-input" type="text" placeholder="例如：轻食、奶茶、咖啡" bindinput="onInputBusiness" value="{{businessType}}" />
    </view>
    <view class="form-item">
      <view class="item-label">面积与费用</view>
      <input class="item-input" type="text" placeholder="例如：30m²，月租 7800 元" bindinput="onInputFee" value="{{feeText}}" />
    </view>
    <view class="form-item">
      <view class="item-label">转让费预期</view>
      <input class="item-input" type="text" placeholder="例如：8 万元，可谈" bindinput="onInputTransferFee" value="{{transferFee}}" />
    </view>
    <view class="form-item">
      <view class="item-label">剩余合同期</view>
      <input class="item-input" type="text" placeholder="例如：18 个月" bindinput="onInputTerm" value="{{remainingTerm}}" />
    </view>
    <radio-group class="form-item" bindchange="onEquipmentIncludedChange">
      <view class="item-label">是否包含设备</view>
      <label class="radio-line"><radio value="true" checked="{{includesEquipment}}" />含设备</label>
      <label class="radio-line"><radio value="false" checked="{{!includesEquipment}}" />不含/待定</label>
    </radio-group>
    <view class="form-item">
      <view class="item-label">补充说明</view>
      <textarea class="item-textarea" placeholder="例如：可带店名、可协助交接、需保密沟通" bindinput="onInputRemark" value="{{remark}}" />
    </view>
    <view class="form-item border-none">
      <view class="item-label">店铺图片 <text class="label-hint">最多 6 张，上传前自动压缩</text></view>
      <view class="attachment-grid">
        <view class="attachment-card" wx:for="{{attachments}}" wx:key="id">
          <image class="attachment-img" src="{{item.url || item.localPath}}" mode="aspectFill" bindtap="onPreviewAttachment" data-url="{{item.url || item.localPath}}" />
          <text class="attachment-remove" bindtap="onRemoveImage" data-index="{{index}}">×</text>
        </view>
        <view class="upload-tile" bindtap="onChooseImages" wx:if="{{attachments.length < 6}}">
          <text class="upload-plus">+</text>
          <text class="upload-hint">{{uploadingImages ? '上传中' : '添加图片'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="form-actions">
    <button class="btn btn-primary" loading="{{submitting}}" disabled="{{submitting || uploadingImages}}" bindtap="onSubmitForm">{{isEditMode ? '保存修改' : '提交委托'}}</button>
  </view>
</view>
