<!-- pages/index/index.wxml -->
<view class="container">
  
  <!-- 头部背景与搜索框 -->
  <view class="header-bg">
    <view class="welcome-text">寻找校园黄金商铺</view>
    <view class="search-bar">
      <icon type="search" size="16" color="#94a3b8" class="search-icon"></icon>
      <input type="text" placeholder="搜索学校、区域、业态，如：奶茶 / 快餐" 
             confirm-type="search" bindconfirm="onSearch" bindinput="onSearchInput" value="{{searchKeyword}}" />
      <button class="search-btn" bindtap="onSearch">搜索</button>
    </view>
  </view>

  <!-- 快捷金刚区分类 -->
  <view class="categories-card card">
    <view class="category-grid">
      <view class="category-item" wx:for="{{categories}}" wx:key="id" 
            bindtap="onCategoryTap" data-type="{{item.type}}" data-val="{{item.val}}">
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 推荐项目列表 (横向滚动) -->
  <view class="section-container" wx:if="{{recommendedList.length > 0}}">
    <view class="section-header flex align-center justify-between">
      <view class="section-title">⭐ 重点推荐项目</view>
      <navigator url="/pages/list/list?recommended=true" class="section-more">查看全部</navigator>
    </view>
    
    <scroll-view class="recommended-scroll" scroll-x="true">
      <view class="recommended-track flex">
        <view class="recommended-item" wx:for="{{recommendedList}}" wx:key="id" bindtap="onProjectDetail" data-id="{{item.id}}">
          <image src="{{item.coverImage}}" mode="aspectFill" class="rec-cover" />
          <view class="rec-info">
            <view class="rec-badge badge badge-online">重点招商</view>
            <view class="rec-title ellipsis">{{item.title}}</view>
            <view class="rec-sub flex justify-between">
              <text class="rec-loc">📍 {{item.city}}·{{item.district}}</text>
              <text class="rec-price">{{item.feeText}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 找不到商铺的横幅引导 -->
  <view class="need-consult-card card flex align-center justify-between" bindtap="onApplyCustom">
    <view class="consult-text-group">
      <view class="consult-main-title">找不到满意的铺位？</view>
      <view class="consult-sub-title">提交您的经营需求，由专业顾问为您配铺</view>
    </view>
    <view class="consult-go-btn">快速提交 ➜</view>
  </view>

  <!-- 最新发布项目 (列表) -->
  <view class="section-container">
    <view class="section-header flex align-center justify-between">
      <view class="section-title">🆕 最新招商项目</view>
      <navigator url="/pages/list/list" open-type="switchTab" class="section-more">查看全部</navigator>
    </view>

    <view class="latest-list" wx:if="{{latestList.length > 0}}">
      <view class="latest-card card flex" wx:for="{{latestList}}" wx:key="id" bindtap="onProjectDetail" data-id="{{item.id}}">
        <image src="{{item.coverImage}}" mode="aspectFill" class="latest-cover" />
        <view class="latest-info flex-1 flex flex-col justify-between">
          <view>
            <view class="latest-title ellipsis">{{item.title}}</view>
            <view class="latest-tags flex flex-wrap">
              <text class="latest-tag">{{item.projectType}}</text>
              <text class="latest-tag">{{item.areaText}}</text>
              <text class="latest-tag" wx:for="{{item.suitableBusiness}}" wx:for-item="biz" wx:key="*this">{{biz}}</text>
            </view>
          </view>
          <view class="latest-bottom flex align-center justify-between">
            <view class="latest-loc">📍 {{item.schoolAlias || item.schoolName || item.district}}</view>
            <view class="latest-price">{{item.feeText}}</view>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>暂无发布项目</view>
  </view>

  <!-- 联系客服快捷悬浮 -->
  <view class="contact-block card flex align-center justify-between" bindtap="onContactAdvisor">
    <view class="flex align-center">
      <text class="advisor-avatar">📞</text>
      <view class="advisor-info">
        <view class="advisor-title">招商顾问专线</view>
        <view class="advisor-desc">直接拨打电话咨询，沟通更高效</view>
      </view>
    </view>
    <view class="call-btn badge">立即联系</view>
  </view>

</view>
