<view class="container form-page">
  <view class="form-header card">
    <view class="form-title">{{isEditMode ? '修改咨询信息' : (projectTitle ? '咨询项目' : '提交找铺需求')}}</view>
    <view class="form-desc" wx:if="{{!projectTitle}}">填写你的经营品类、预算和区域偏好，招商顾问会协助匹配合适铺位。</view>
  </view>

  <view class="project-context card" wx:if="{{projectTitle && !isEditMode}}">
    <image class="project-context-cover" src="{{projectCover}}" mode="aspectFill" wx:if="{{projectCover}}" />
    <view class="project-context-info">
      <view class="project-context-label">正在咨询</view>
      <view class="project-context-title">{{projectTitle}}</view>
      <view class="project-context-fee" wx:if="{{projectFeeText}}">{{projectFeeText}}</view>
    </view>
  </view>

  <view class="form-card card">
    <view class="form-item">
      <view class="item-label">称呼</view>
      <input class="item-input" type="text" maxlength="20" placeholder="例如：张老板" bindinput="onInputName" value="{{name}}" />
    </view>
    <view class="form-item">
      <view class="item-label">手机号</view>
      <input class="item-input" type="number" maxlength="11" placeholder="用于顾问联系" bindinput="onInputPhone" value="{{phone}}" />
    </view>
    <view class="form-item">
      <view class="item-label">经营品类</view>
      <picker mode="selector" range="{{businesses}}" bindchange="onBusinessChange">
        <view class="picker-value">{{businessType || '请选择经营品类'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <view class="item-label">投资预算</view>
      <picker mode="selector" range="{{budgets}}" bindchange="onBudgetChange">
        <view class="picker-value">{{budgetRange || '请选择预算范围'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <view class="item-label">意向区域</view>
      <input class="item-input" type="text" maxlength="50" placeholder="例如：天河、番禺、增城" bindinput="onInputRegion" value="{{regionPreference}}" />
    </view>
    <radio-group class="form-item" bindchange="onExperienceChange">
      <view class="item-label">是否有校园经营经验</view>
      <label class="radio-line"><radio value="true" checked="{{hasCampusExperience}}" />有</label>
      <label class="radio-line"><radio value="false" checked="{{!hasCampusExperience}}" />暂无</label>
    </radio-group>
    <view class="form-item">
      <view class="item-label">补充说明</view>
      <textarea class="item-textarea" maxlength="500" placeholder="例如：希望尽快进场、需要排烟、偏好食堂档口" bindinput="onInputRemark" value="{{remark}}" />
    </view>
    <view class="form-item border-none">
      <view class="item-label">补充图片 <text class="label-hint">最多 6 张，上传前自动压缩</text></view>
      <view class="attachment-grid">
        <view class="attachment-card" wx:for="{{attachments}}" wx:key="id">
          <image class="attachment-img" src="{{item.url || item.localPath}}" mode="aspectFill" bindtap="onPreviewAttachment" data-url="{{item.url || item.localPath}}" />
          <text class="attachment-remove" bindtap="onRemoveImage" data-index="{{index}}">×</text>
        </view>
        <view class="upload-tile" bindtap="onChooseImages" wx:if="{{attachments.length < 6}}">
          <text class="upload-plus">+</text>
          <text class="upload-hint">{{uploadingImages ? '上传中' : '添加图片'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="privacy-consent" wx:if="{{!isEditMode}}" bindtap="onTogglePrivacy">
    <checkbox checked="{{privacyAccepted}}" color="#3b82f6" />
    <text class="privacy-text">我已阅读并同意</text>
    <text class="privacy-link" catchtap="onGoPrivacy">《隐私政策》</text>
  </view>

  <view class="form-actions">
    <button class="btn btn-secondary" bindtap="onClearForm" wx:if="{{!isEditMode}}">清空</button>
    <button class="btn btn-primary" style="{{isEditMode ? 'flex: 1;' : ''}}" loading="{{submitting}}" disabled="{{submitting || uploadingImages}}" bindtap="onSubmitForm">{{isEditMode ? '保存修改' : '提交咨询'}}</button>
  </view>
</view>
