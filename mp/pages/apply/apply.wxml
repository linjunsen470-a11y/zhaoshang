<view class="container">
  <view class="form-header">
    <view class="header-title">提交找铺需求</view>
    <view class="header-desc">留下经营需求后，招商顾问会在 24 小时内联系，并匹配合适的校园铺位、转让店或设备资源。</view>
  </view>

  <view class="form-body">
    <view class="card project-info-card flex align-center" wx:if="{{projectTitle}}">
      <text class="pin-icon">📍</text>
      <view class="flex-1">
        <view class="info-label">意向项目</view>
        <view class="info-title ellipsis">{{projectTitle}}</view>
      </view>
    </view>

    <view class="card form-card">
      <view class="form-item">
        <view class="item-label flex align-center"><text class="required-star">*</text>您的称呼</view>
        <input class="item-input" type="text" placeholder="例如：张总、李老板" bindinput="onInputName" value="{{name}}" />
      </view>

      <view class="form-item">
        <view class="item-label flex align-center"><text class="required-star">*</text>联系手机号</view>
        <input class="item-input" type="number" maxlength="11" placeholder="用于招商顾问与您联系" bindinput="onInputPhone" value="{{phone}}" />
      </view>

      <view class="form-item">
        <view class="item-label flex align-center"><text class="required-star">*</text>经营品类</view>
        <picker mode="selector" range="{{businesses}}" bindchange="onBusinessChange" value="{{businessIndex}}">
          <view class="picker-value flex justify-between align-center">
            <text class="{{businessType ? 'value-set' : 'value-placeholder'}}">{{businessType ? businessType : '请选择主营品类'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <view class="item-label flex align-center"><text class="required-star">*</text>投资预算</view>
        <picker mode="selector" range="{{budgets}}" bindchange="onBudgetChange" value="{{budgetIndex}}">
          <view class="picker-value flex justify-between align-center">
            <text class="{{budgetRange ? 'value-set' : 'value-placeholder'}}">{{budgetRange ? budgetRange : '请选择预算区间'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <view class="item-label">意向区域 <text class="label-hint">(可选)</text></view>
        <input class="item-input" type="text" placeholder="例如：广州增城、天河、大学城" bindinput="onInputRegion" value="{{regionPreference}}" />
      </view>

      <view class="form-item">
        <view class="item-label">是否有校园经营经验 <text class="label-hint">(可选)</text></view>
        <radio-group class="experience-group flex align-center" bindchange="onExperienceChange">
          <label class="radio-label flex align-center">
            <radio value="true" checked="{{hasCampusExperience === true}}" color="#3b82f6" />
            <text class="radio-text">有经验</text>
          </label>
          <label class="radio-label flex align-center" style="margin-left: 60rpx;">
            <radio value="false" checked="{{hasCampusExperience === false}}" color="#3b82f6" />
            <text class="radio-text">暂无经验</text>
          </label>
        </radio-group>
      </view>

      <view class="form-item border-none">
        <view class="item-label">其他需求说明 <text class="label-hint">(可选)</text></view>
        <textarea class="item-textarea" placeholder="可填写对水电、排烟、面积、预算测算、品牌加盟等补充需求"
                  bindinput="onInputRemark" value="{{remark}}" maxlength="200" />
        <view class="char-count">{{remark.length}}/200</view>
      </view>
    </view>

    <button class="btn btn-primary submit-btn" bindtap="onSubmitForm" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '确认提交需求'}}
    </button>

    <button class="btn btn-secondary" style="margin-top:16rpx;" bindtap="onClearForm" disabled="{{submitting}}">
      清空表单
    </button>
  </view>
</view>
