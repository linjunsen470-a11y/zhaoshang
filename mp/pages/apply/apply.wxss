/* pages/apply/apply.wxss */

/* 头部横幅 */
.form-header {
  background: linear-gradient(135deg, #3b82f6 0%, #1e3a8a 100%);
  color: #ffffff;
  padding: 40rpx 40rpx 50rpx 40rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 24rpx;
  opacity: 0.85;
  line-height: 1.5;
}

/* 表单容器 */
.form-body {
  padding: 30rpx;
  margin-top: -20rpx;
}

/* 意向项目提示卡片 */
.project-info-card {
  background-color: #eff6ff;
  border: 1rpx solid #bfdbfe;
  padding: 24rpx 30rpx;
}

.pin-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.info-label {
  font-size: 22rpx;
  color: #1e40af;
}

.info-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e3a8a;
  margin-top: 4rpx;
}

/* 表单项 */
.form-card {
  padding: 10rpx 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.border-none {
  border-bottom: none;
}

.item-label {
  font-size: 26rpx;
  color: #475569;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.required-star {
  color: #ef4444;
  margin-right: 6rpx;
}

.label-hint {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 400;
}

/* 输入框 */
.item-input {
  font-size: 28rpx;
  color: #1e293b;
  height: 60rpx;
  width: 100%;
}

/* 选择器样式 */
.picker-value {
  height: 60rpx;
}

.value-set {
  font-size: 28rpx;
  color: #1e293b;
}

.value-placeholder {
  font-size: 28rpx;
  color: #94a3b8;
}

.picker-arrow {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 单选框 */
.experience-group {
  height: 60rpx;
}

.radio-label {
  font-size: 28rpx;
  color: #334155;
}

.radio-text {
  margin-left: 10rpx;
}

/* 文本域 */
.item-textarea {
  font-size: 28rpx;
  color: #1e293b;
  height: 180rpx;
  width: 100%;
  padding: 16rpx 0;
  line-height: 1.5;
}

.char-count {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: right;
  margin-top: 6rpx;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 40rpx;
  height: 96rpx;
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.25);
}
