.form-page {
  padding-bottom: 48rpx;
}

.form-header {
  background: linear-gradient(135deg, #2563eb 0%, #0f766e 100%);
  color: #ffffff;
  padding: 40rpx;
  border-radius: 0 !important;
}

.form-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.form-desc {
  font-size: 24rpx;
  opacity: 0.9;
  line-height: 1.6;
}

.form-card {
  padding: 8rpx 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.border-none {
  border-bottom: none;
}

.item-label {
  font-size: 26rpx;
  color: #475569;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.label-hint {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 400;
}

.item-input {
  font-size: 28rpx;
  color: #1e293b;
  height: 60rpx;
  width: 100%;
}

.picker-value {
  min-height: 60rpx;
  font-size: 28rpx;
  color: #1e293b;
}

.radio-line {
  font-size: 28rpx;
  color: #334155;
  margin-right: 40rpx;
}

.item-textarea {
  font-size: 28rpx;
  color: #1e293b;
  min-height: 180rpx;
  width: 100%;
  padding: 16rpx 0;
  line-height: 1.5;
}

.attachment-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.attachment-card,
.upload-tile {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f8fafc;
}

.attachment-img {
  width: 100%;
  height: 100%;
}

.attachment-remove {
  position: absolute;
  right: 6rpx;
  top: 6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.78);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 34rpx;
  text-align: center;
}

.upload-tile {
  border: 1rpx dashed #94a3b8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-plus {
  font-size: 48rpx;
  color: #64748b;
  line-height: 1;
}

.upload-hint {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 10rpx;
}

.project-context {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 30rpx 24rpx;
  padding: 24rpx;
}

.project-context-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #e2e8f0;
}

.project-context-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.project-context-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.4;
}

.project-context-fee {
  font-size: 24rpx;
  color: #3b82f6;
  margin-top: 8rpx;
  font-weight: 600;
}

.privacy-consent {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding: 20rpx 30rpx 0;
  font-size: 24rpx;
  color: #64748b;
}

.privacy-text {
  margin-left: 8rpx;
}

.privacy-link {
  color: #3b82f6;
  font-weight: 600;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx 0;
}

.form-actions .btn {
  flex: 1;
}
