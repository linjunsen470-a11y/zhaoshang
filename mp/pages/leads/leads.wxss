/* pages/leads/leads.wxss */

.leads-header {
  background-color: #ffffff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #e2e8f0;
  font-size: 26rpx;
}

.phone-label {
  color: #64748b;
}

.phone-number {
  color: #0f172a;
  font-weight: 700;
}

.change-phone-btn {
  color: #3b82f6;
  font-weight: 600;
}

.leads-body {
  padding: 30rpx;
}

.lead-card {
  padding: 30rpx;
  border: 1rpx solid #e2e8f0;
}

.lead-card-header {
  border-bottom: 1rpx solid #f1f5f9;
  padding-bottom: 16rpx;
  margin-bottom: 20rpx;
}

.lead-project-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  flex: 1;
  margin-right: 20rpx;
}

.link-text {
  color: #3b82f6;
  text-decoration: underline;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 30rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 规格参数区域 */
.lead-specs {
  background-color: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.spec-grid {
  display: flex;
  flex-wrap: wrap;
}

.spec-cell {
  width: 50%;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.spec-cell:nth-last-child(-n+2) {
  margin-bottom: 0;
}

.spec-lbl {
  color: #64748b;
}

.spec-val {
  color: #334155;
  font-weight: 600;
}

.spec-desc-row {
  margin-top: 16rpx;
  border-top: 1rpx dashed #e2e8f0;
  padding-top: 12rpx;
  font-size: 24rpx;
}

.spec-val-desc {
  color: #475569;
  line-height: 1.4;
  word-break: break-all;
}

/* 底部编号和时间 */
.lead-time-footer {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 20rpx;
}

.lead-id-lbl {
  color: #cbd5e1;
}

/* 等待跟进提示 */
.no-follow-tip {
  font-size: 24rpx;
  color: #64748b;
  background-color: #f8fafc;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  text-align: center;
}

/* 时间轴部分 */
.follow-timeline-section {
  border-top: 1rpx solid #f1f5f9;
  padding-top: 20rpx;
  margin-top: 20rpx;
}

.timeline-toggle-bar {
  padding: 12rpx 0;
}

.timeline-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.timeline-summary-lbl {
  font-size: 24rpx;
  color: #475569;
  font-weight: 600;
}

.toggle-arrow {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 时间轴节点 */
.timeline-content {
  margin-top: 20rpx;
  padding-left: 20rpx;
  border-left: 2rpx dashed #cbd5e1;
  margin-left: 14rpx;
}

.timeline-node {
  position: relative;
  padding-bottom: 24rpx;
}

.timeline-node:last-child {
  padding-bottom: 0;
}

.node-dot {
  position: absolute;
  left: -27rpx;
  top: 10rpx;
  width: 12rpx;
  height: 12rpx;
  background-color: #3b82f6;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  box-shadow: 0 0 0 4rpx rgba(59, 130, 246, 0.2);
}

.timeline-node:first-child .node-dot {
  background-color: #10b981;
  box-shadow: 0 0 0 6rpx rgba(16, 185, 129, 0.25);
}

.node-body {
  background-color: #f1f5f9;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.node-time-header {
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.node-operator {
  font-weight: 600;
  color: #334155;
}

.node-time {
  color: #94a3b8;
}

.node-message {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.5;
  word-break: break-all;
}

.node-next-follow {
  font-size: 22rpx;
  color: #2563eb;
  margin-top: 10rpx;
  font-weight: 500;
}

/* 空状态和加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #94a3b8;
  font-size: 26rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 30rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 40rpx;
}

.reset-btn {
  font-size: 26rpx;
  padding: 10rpx 40rpx;
}
