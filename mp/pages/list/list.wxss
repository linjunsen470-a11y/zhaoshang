/* pages/list/list.wxss */

.container {
  min-height: 100vh;
}

/* 顶部固定搜索及筛选栏 */
.sticky-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.02);
}

.search-section {
  padding: 16rpx 30rpx 10rpx 30rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f1f5f9;
  border-radius: 100rpx;
  padding: 8rpx 24rpx;
  position: relative;
}

.search-icon {
  margin-right: 12rpx;
}

.search-box input {
  flex: 1;
  font-size: 26rpx;
  height: 56rpx;
  color: #1e293b;
}

.clear-btn {
  font-size: 28rpx;
  color: #94a3b8;
  padding: 10rpx;
}

/* 筛选 Tab 水平排布 */
.filter-tabs {
  display: flex;
  border-top: 1rpx solid #f8fafc;
  height: 84rpx;
  align-items: center;
}

.filter-tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #475569;
  height: 100%;
  border-right: 1rpx solid #f8fafc;
}

.filter-tab-item:last-child {
  border-right: none;
}

.tab-text {
  max-width: 110rpx;
}

.arrow-icon {
  font-size: 14rpx;
  margin-left: 8rpx;
  color: #94a3b8;
  transition: transform 0.2s ease;
}

.tab-open .arrow-icon {
  transform: rotate(180deg);
  color: #3b82f6;
}

.tab-open {
  color: #3b82f6;
  font-weight: 600;
}

.active-filter {
  color: #3b82f6;
  font-weight: 600;
}

/* 筛选项下拉面板抽屉 */
.filter-drawer-container {
  position: fixed;
  top: 166rpx; /* search + tab height */
  left: 0;
  width: 100%;
  height: calc(100vh - 166rpx);
  z-index: 90;
}

.drawer-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(15, 23, 42, 0.4);
}

.drawer-content {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  max-height: 520rpx;
  background-color: #ffffff;
  z-index: 10;
  border-bottom-left-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.1);
  padding: 10rpx 0;
}

.option-item {
  padding: 24rpx 40rpx;
  font-size: 26rpx;
  color: #475569;
  border-bottom: 1rpx solid #f8fafc;
}

.option-item:last-child {
  border-bottom: none;
}

.selected-option {
  color: #3b82f6;
  background-color: #eff6ff;
  font-weight: 600;
}

/* 列表主体区域 */
.list-body {
  padding: 180rpx 30rpx 40rpx 30rpx; /* 留出顶部固定栏空间 */
}

.filter-tip {
  background-color: #eff6ff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #1e40af;
  font-weight: 500;
}

.reset-btn-link {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
}

/* 项目卡片 */
.project-card {
  padding: 24rpx;
}

.card-top {
  border-bottom: 1rpx solid #f1f5f9;
  padding-bottom: 20rpx;
  margin-bottom: 16rpx;
}

.project-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #e2e8f0;
  flex-shrink: 0;
}

.project-main {
  height: 160rpx;
  overflow: hidden;
}

.project-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.project-meta {
  margin-bottom: 8rpx;
}

.school-tag {
  font-size: 22rpx;
  color: #64748b;
  margin-left: 12rpx;
  max-width: 260rpx;
}

.price-area-row {
  margin-top: auto;
}

.area-val {
  font-size: 24rpx;
  color: #475569;
}

.price-val {
  font-size: 28rpx;
  color: #ef4444;
  font-weight: 700;
}

.card-bottom {
  font-size: 22rpx;
}

.biz-tag-inline {
  background-color: #f1f5f9;
  color: #475569;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.suit-label {
  color: #64748b;
}

.update-time {
  color: #94a3b8;
  flex-shrink: 0;
}

/* 加载中与空状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #94a3b8;
  font-size: 26rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 30rpx;
}

.reset-btn {
  font-size: 26rpx;
  padding: 10rpx 40rpx;
}

.btn-sm {
  height: auto;
  line-height: 1.5;
}

.fav-local-tip {
  margin: 0 30rpx 16rpx;
  padding: 12rpx 20rpx;
  background: #fffbeb;
  border: 1rpx solid #fef3c7;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #d97706;
  text-align: center;
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.error-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.error-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 28rpx;
}
