# Payload
PAYLOAD_SECRET=your-very-strong-secret-change-me-in-production

# Database
# Docker compose:
DATABASE_URI=postgres://payload:change-this-postgres-password@db:5432/payload

# Local dev example:
# DATABASE_URI=postgres://payload:payload@localhost:5432/payload

# Public server URL for admin links and generated media URLs.
# Use 127.0.0.1 (not localhost) so WeChat DevTools matches mp/config.js API_URL.
PAYLOAD_PUBLIC_SERVER_URL=http://127.0.0.1:3000
# WeChat mini-program auth.
# Use dev for local debugging without a real AppSecret; use wechat in production.
WECHAT_AUTH_MODE=dev
WECHAT_AUTH_DEV_OPENID=dev-openid-local
WECHAT_APPID=wx22fb8f72be05d5c3
WECHAT_APP_SECRET=

# Schema push: set true only when applying collection schema changes, then run:
#   pnpm --dir backend exec tsx scripts/push-schema.ts
# Leave false during normal dev to avoid slow/blocked first API requests.
PAYLOAD_DB_PUSH=false
